---
import { formatStars, formatDelta } from '../lib/github';

interface Props {
  name: string;
  tagline: string;
  href: string;
  author?: string;
  stars: number | null;
  delta7d?: number | null;
  badge?: string;
  featured?: boolean;
}

const { name, tagline, href, author, stars, delta7d, badge, featured } = Astro.props;
const deltaLabel = formatDelta(delta7d ?? null);
const starsStr = formatStars(stars);

const badgeColors: Record<string, string> = {
  'Skill': 'bg-emerald-50 text-emerald-700',
  'MCP': 'bg-purple-50 text-purple-700',
  'Cursor': 'bg-sky-50 text-sky-700',
  'GPT': 'bg-teal-50 text-teal-700',
  'Agent': 'bg-orange-50 text-orange-700',
  'IDE': 'bg-indigo-50 text-indigo-700',
  'CLI': 'bg-slate-100 text-slate-700',
  'Framework': 'bg-amber-50 text-amber-700',
  'Automation': 'bg-rose-50 text-rose-700',
  'Browser': 'bg-cyan-50 text-cyan-700',
};
const badgeClass = badge ? (badgeColors[badge] ?? 'bg-[var(--color-accent-soft)] text-[var(--color-accent)]') : '';
---

<article
  class:list={[
    'group relative flex flex-col w-[280px] sm:w-[300px] shrink-0 snap-start',
    'bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl px-4 py-3.5 transition',
    'hover:border-[var(--color-border-strong)] hover:shadow-sm',
    featured ? 'ring-1 ring-[var(--color-accent)]/20' : '',
  ]}
>
  <a href={href} class="absolute inset-0 rounded-xl" aria-label={name}></a>

  <div class="relative pointer-events-none flex items-center gap-2 mb-1">
    <h3 class="text-[15px] font-semibold text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition truncate">
      {name}
    </h3>
    {badge && (
      <span class={`inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-medium uppercase tracking-wide shrink-0 ${badgeClass}`}>
        {badge}
      </span>
    )}
  </div>

  <p class="relative pointer-events-none text-xs text-[var(--color-fg-muted)] leading-snug line-clamp-2 mb-2.5 min-h-[2.4em]">
    {tagline}
  </p>

  <div class="relative pointer-events-none flex items-center justify-between text-xs text-[var(--color-fg-muted)] mt-auto">
    {author && <span class="truncate">{author}</span>}
    <span class="inline-flex items-center gap-1 font-medium text-[var(--color-fg)] tnum shrink-0">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="text-[var(--color-fg-faint)]">
        <path d="M12 2l2.9 6.9L22 10l-5.5 4.8L18 22l-6-3.6L6 22l1.5-7.2L2 10l7.1-1.1L12 2z" />
      </svg>
      {starsStr}
      {deltaLabel && (
        <span class="text-[var(--color-positive)] font-normal ml-0.5">{deltaLabel}</span>
      )}
    </span>
  </div>
</article>
