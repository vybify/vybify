---
interface Props {
  command: string;
  prefix?: string;
  label?: string;
}

const { command, prefix = '$', label } = Astro.props;
---

<div
  class="vyb-copy group relative rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)]/40 transition"
>
  {label && (
    <div class="absolute -top-2 left-4 px-2 text-[10px] uppercase tracking-widest text-[var(--color-fg-muted)] bg-[var(--color-bg)]">
      {label}
    </div>
  )}
  <pre class="px-4 py-4 pr-14 overflow-x-auto"><code class="font-mono text-sm">{prefix && (<span class="text-[var(--color-fg-muted)] select-none mr-2">{prefix}</span>)}<span class="vyb-copy-text">{command}</span></code></pre>
  <button
    type="button"
    class="vyb-copy-btn absolute top-2 right-2 px-2.5 py-1 text-xs font-medium rounded-md bg-[var(--color-bg)]/80 border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/60 transition opacity-0 group-hover:opacity-100 focus:opacity-100"
    aria-label="Copy command"
  >
    Copy
  </button>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.vyb-copy').forEach((wrap) => {
    const btn = wrap.querySelector<HTMLButtonElement>('.vyb-copy-btn');
    const text = wrap.querySelector<HTMLElement>('.vyb-copy-text');
    if (!btn || !text) return;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(text.textContent ?? '');
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('text-[var(--color-accent-2)]', 'border-[var(--color-accent-2)]/60');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('text-[var(--color-accent-2)]', 'border-[var(--color-accent-2)]/60');
        }, 1500);
      } catch (err) {
        console.error('Copy failed', err);
      }
    });
  });
</script>
