---
interface Props {
  command: string;
  label?: string;
}

const { command, label } = Astro.props;
---

<div class="vyb-copy">
  {label && <p class="label mb-1.5">{label}</p>}
  <div class="relative">
    <pre class="bg-[var(--color-fg)] text-white text-sm font-mono px-4 py-3 pr-14 rounded-lg overflow-x-auto"><code><span class="text-white/40 select-none mr-2">$</span><span class="vyb-copy-text">{command}</span></code></pre>
    <button
      type="button"
      class="vyb-copy-btn absolute top-2 right-2 px-2.5 py-1 text-xs font-medium rounded-md bg-white/10 text-white/80 hover:bg-white/20 hover:text-white transition"
      aria-label="Copy command"
    >
      Copy
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.vyb-copy').forEach((wrap) => {
    const btn = wrap.querySelector<HTMLButtonElement>('.vyb-copy-btn');
    const text = wrap.querySelector<HTMLElement>('.vyb-copy-text');
    if (!btn || !text) return;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(text.textContent ?? '');
        const original = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => {
          btn.textContent = original;
        }, 1500);
      } catch (err) {
        console.error('Copy failed', err);
      }
    });
  });
</script>
