---
import { formatStars, formatDelta } from '../lib/github';
import UpvoteScript from './UpvoteScript.astro';

interface Props {
  rank?: number;
  name: string;
  tagline: string;
  href: string;
  url: string;
  github?: string;
  author?: string;
  tags: string[];
  stars: number | null;
  delta7d?: number | null;
  badge?: string;
  featured?: boolean;
  entryType?: 'project' | 'skill';
  entrySlug?: string;
}

const { name, tagline, href, author, tags, stars, delta7d, badge, featured, entryType, entrySlug } = Astro.props;
const deltaLabel = formatDelta(delta7d ?? null);
const starsStr = formatStars(stars);
---

<article
  class:list={[
    'group relative bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl px-5 py-4 transition',
    'hover:border-[var(--color-border-strong)] hover:shadow-sm',
    featured ? 'ring-1 ring-[var(--color-accent)]/20' : '',
  ]}
>
  <a href={href} class="absolute inset-0 rounded-xl" aria-label={name}></a>

  <div class="relative pointer-events-none flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 flex-wrap">
        <h3 class="text-[17px] font-semibold text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition truncate">
          {name}
        </h3>
        {badge && (
          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium uppercase tracking-wide bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
            {badge}
          </span>
        )}
        {featured && (
          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium uppercase tracking-wide bg-yellow-50 text-yellow-700 border border-yellow-200">
            Featured
          </span>
        )}
      </div>

      <p class="mt-1 text-sm text-[var(--color-fg-muted)] leading-snug line-clamp-2">
        {tagline}
      </p>

      <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1.5 text-xs text-[var(--color-fg-muted)]">
        {author && (
          <>
            <span class="pointer-events-none">{author}</span>
            <span class="text-[var(--color-fg-faint)]" aria-hidden="true">·</span>
          </>
        )}
        <div class="relative pointer-events-auto flex flex-wrap gap-1.5">
          {tags.slice(0, 4).map((tag) => (
            <a
              href={`/tag/${encodeURIComponent(tag.toLowerCase())}`}
              class="inline-flex items-center px-1.5 py-0.5 rounded bg-[var(--color-bg)] text-[var(--color-fg-muted)] hover:bg-[var(--color-accent-soft)] hover:text-[var(--color-accent)] transition"
            >
              {tag}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="relative pointer-events-none shrink-0 text-right flex flex-col items-end gap-1.5">
      <div class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-fg)] tnum">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="text-[var(--color-fg-faint)]">
          <path d="M12 2l2.9 6.9L22 10l-5.5 4.8L18 22l-6-3.6L6 22l1.5-7.2L2 10l7.1-1.1L12 2z" />
        </svg>
        <span>{starsStr}</span>
      </div>
      {deltaLabel && (
        <div class="text-xs text-[var(--color-positive)] tnum">
          {deltaLabel} 7d
        </div>
      )}
      {entryType && entrySlug && (
        <button
          type="button"
          class="vyb-upvote pointer-events-auto inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-fg-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition"
          data-entry-type={entryType}
          data-entry-slug={entrySlug}
          aria-label={`Upvote ${name}`}
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="vyb-upvote-icon" aria-hidden="true">
            <path d="M12 19V5M5 12l7-7 7 7" />
          </svg>
          <span class="vyb-upvote-count tnum">0</span>
        </button>
      )}
    </div>
  </div>
</article>
<UpvoteScript />
