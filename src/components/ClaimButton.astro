---
interface Props {
  entryType: 'project' | 'skill';
  entrySlug: string;
  githubRepo?: string;
}

const { entryType, entrySlug, githubRepo } = Astro.props;
---

<div
  class="vyb-claim"
  data-entry-type={entryType}
  data-entry-slug={entrySlug}
  data-github-repo={githubRepo ?? ''}
>
  <div class="vyb-claim-loading text-sm text-[var(--color-fg-muted)]">Loading...</div>

  <!-- Not claimed yet -->
  <div class="vyb-claim-unclaimed hidden">
    <button
      type="button"
      class="vyb-claim-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-dashed border-[var(--color-border-strong)] text-sm text-[var(--color-fg-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent-soft)] transition"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      </svg>
      Claim this {entryType}
    </button>
    <p class="vyb-claim-needs-github hidden text-xs text-[var(--color-fg-muted)] mt-1.5">
      Sign in with GitHub to verify ownership.
    </p>
  </div>

  <!-- Pending claim -->
  <div class="vyb-claim-pending hidden">
    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-yellow-50 border border-yellow-200 text-xs font-medium text-yellow-800">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      Claim pending review
    </span>
  </div>

  <!-- Approved claim -->
  <div class="vyb-claim-approved hidden">
    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-green-50 border border-green-200 text-xs font-medium text-green-800">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        <polyline points="9 12 11.5 14.5 15.5 10" />
      </svg>
      <span>Claimed by <span class="vyb-claim-owner font-semibold"></span></span>
    </span>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.vyb-claim').forEach((wrap) => {
    const entryType = wrap.dataset.entryType!;
    const entrySlug = wrap.dataset.entrySlug!;
    const githubRepo = wrap.dataset.githubRepo || '';

    const loading = wrap.querySelector<HTMLElement>('.vyb-claim-loading')!;
    const unclaimed = wrap.querySelector<HTMLElement>('.vyb-claim-unclaimed')!;
    const pending = wrap.querySelector<HTMLElement>('.vyb-claim-pending')!;
    const approved = wrap.querySelector<HTMLElement>('.vyb-claim-approved')!;
    const needsGithub = wrap.querySelector<HTMLElement>('.vyb-claim-needs-github')!;
    const ownerEl = wrap.querySelector<HTMLElement>('.vyb-claim-owner')!;
    const btn = wrap.querySelector<HTMLButtonElement>('.vyb-claim-btn')!;

    function show(el: HTMLElement) {
      [loading, unclaimed, pending, approved].forEach((e) => e.classList.add('hidden'));
      el.classList.remove('hidden');
    }

    // Fetch current claim status
    fetch(`/api/claim?entry_type=${entryType}&entry_slug=${entrySlug}`)
      .then((r) => r.json())
      .then((data) => {
        if (data.claim) {
          if (data.claim.status === 'approved') {
            ownerEl.textContent = data.claim.owner_name;
            show(approved);
          } else if (data.claim.is_mine) {
            show(pending);
          } else {
            show(unclaimed);
          }
        } else {
          show(unclaimed);
          if (data.signed_in && !data.has_github) {
            needsGithub.classList.remove('hidden');
          }
        }
      })
      .catch(() => show(unclaimed));

    // Claim button click
    btn.addEventListener('click', async () => {
      try {
        const res = await fetch('/api/claim', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            entry_type: entryType,
            entry_slug: entrySlug,
            github_repo: githubRepo,
          }),
        });

        if (res.status === 401) {
          window.location.href = '/login';
          return;
        }

        const data = await res.json();
        if (data.error) {
          if (data.needs_github) {
            needsGithub.classList.remove('hidden');
          } else {
            alert(data.error);
          }
          return;
        }

        if (data.auto_approved) {
          ownerEl.textContent = 'you';
          show(approved);
        } else {
          show(pending);
        }
      } catch {
        alert('Something went wrong. Try again.');
      }
    });
  });
</script>
