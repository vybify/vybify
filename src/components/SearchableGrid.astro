---
import { getCollection } from 'astro:content';
import Card from './Card.astro';
import { withStars } from '../lib/github';

interface Props {
  type?: 'all' | 'project' | 'skill';
  showHeader?: boolean;
}

const { type = 'all', showHeader = true } = Astro.props;

const projectsRaw = await withStars(await getCollection('projects'));
const skillsRaw = await withStars(await getCollection('skills'));

const kindBadge: Record<string, string | undefined> = {
  'mcp-server': 'MCP',
  'claude-code-skill': 'Skill',
  'cursor-rule': 'Cursor',
  'custom-gpt': 'GPT',
  other: undefined,
};

const tagBadgeMap: [string[], string][] = [
  [['agent', 'autonomous'], 'Agent'],
  [['ide', 'editor', 'vscode', 'jetbrains'], 'IDE'],
  [['cli'], 'CLI'],
  [['framework', 'sdk', 'library'], 'Framework'],
  [['mcp'], 'MCP'],
  [['automation'], 'Automation'],
  [['browser'], 'Browser'],
];

function projectBadge(tags: string[]): string | undefined {
  const lower = new Set(tags.map((t) => t.toLowerCase()));
  for (const [keys, label] of tagBadgeMap) {
    if (keys.some((k) => lower.has(k))) return label;
  }
  return undefined;
}

type EntryRow = {
  _type: 'project' | 'skill';
  _id: string;
  data: any;
  stars: number | null;
  delta7d: number | null;
  badge?: string;
};

const projects: EntryRow[] = projectsRaw.map((e) => ({
  _type: 'project',
  _id: `p-${e.id}`,
  data: e.data,
  stars: e.stars,
  delta7d: e.delta7d,
  badge: projectBadge(e.data.tags ?? []),
}));

const skills: EntryRow[] = skillsRaw.map((e) => ({
  _type: 'skill',
  _id: `s-${e.id}`,
  data: e.data,
  stars: e.stars,
  delta7d: e.delta7d,
  badge: kindBadge[e.data.kind],
}));

let entries: EntryRow[] = [];
if (type === 'all' || type === 'project') entries.push(...projects);
if (type === 'all' || type === 'skill') entries.push(...skills);

// Default sort: stars desc
entries.sort((a, b) => (b.stars ?? -1) - (a.stars ?? -1));

// Tag frequency for the chip row
const tagCounts: Record<string, number> = {};
for (const e of entries) {
  for (const t of e.data.tags ?? []) {
    const key = t.toLowerCase();
    tagCounts[key] = (tagCounts[key] ?? 0) + 1;
  }
}
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([t]) => t)
  .slice(0, 18);

// Hot score: rewards velocity relative to size + recency
// Formula: (delta7d / ln(stars + 2)) * recencyBoost
// recencyBoost: entries added in last 14 days get 2x, last 30 get 1.5x
function computeHotScore(e: EntryRow): number {
  const delta = e.delta7d ?? 0;
  const stars = e.stars ?? 0;
  if (delta <= 0 && stars <= 0) return 0;
  const velocity = delta / Math.log(stars + 2);
  const addedMs = new Date(e.data.addedAt).getTime();
  const ageMs = Date.now() - addedMs;
  const ageDays = ageMs / 86400000;
  const recencyBoost = ageDays <= 14 ? 2 : ageDays <= 30 ? 1.5 : 1;
  return velocity * recencyBoost;
}

// Search index payload
const searchIndex = entries.map((e) => ({
  i: e._id,
  n: e.data.name,
  t: e.data.tagline,
  tags: (e.data.tags ?? []).map((x: string) => x.toLowerCase()),
  bw: e.data.builtWith ?? [],
  author: e.data.author ?? '',
}));
---

<section class="vyb-search" data-default-type={type}>
  {showHeader && (
    <div class="mb-6">
      <div class="relative">
        <svg
          class="absolute left-4 top-1/2 -translate-y-1/2 text-[var(--color-fg-faint)]"
          width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7" />
          <path d="m21 21-4.3-4.3" />
        </svg>
        <input
          id="vyb-q"
          type="search"
          placeholder="Search projects, skills, tools, tags…"
          autocomplete="off"
          class="w-full pl-11 pr-12 py-3 bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl placeholder:text-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent-soft)] text-base transition"
        />
        <kbd class="hidden md:inline-flex absolute right-3 top-1/2 -translate-y-1/2 font-mono text-[11px] px-1.5 py-0.5 border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-fg-muted)] rounded">
          /
        </kbd>
      </div>

      <div class="flex flex-wrap items-center gap-2 mt-4">
        {type === 'all' && (
          <div class="vyb-type inline-flex p-0.5 bg-[var(--color-card)] border border-[var(--color-border)] rounded-lg" role="tablist">
            <button data-type="all" class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition">All</button>
            <button data-type="project" class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition">Projects</button>
            <button data-type="skill" class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition">Skills <span class="ml-1 text-[var(--color-fg-faint)]">(installable)</span></button>
          </div>
        )}

        <div class="vyb-sort inline-flex p-0.5 bg-[var(--color-card)] border border-[var(--color-border)] rounded-lg" role="tablist">
          <button data-sort="stars" class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition">All-time</button>
          <button data-sort="hot" class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition">Hot</button>
          <button data-sort="rising" class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition">Rising</button>
          <button data-sort="recent" class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition">New</button>
          <button data-sort="alpha" class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition">A–Z</button>
        </div>

        <span class="ml-auto text-sm text-[var(--color-fg-muted)] tnum">
          <span id="vyb-count">{entries.length}</span> results
        </span>
      </div>

      {topTags.length > 0 && (
        <div class="vyb-tags flex flex-wrap gap-1.5 mt-4">
          {topTags.map((t) => (
            <button
              data-tag={t}
              class="px-2.5 py-1 rounded-full text-xs bg-[var(--color-card)] border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:bg-[var(--color-accent-soft)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent-soft)] transition"
            >
              #{t}
            </button>
          ))}
        </div>
      )}
    </div>
  )}

  <div id="vyb-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-3">
    {entries.map((e) => {
      const detailHref = `/${e._type === 'project' ? 'projects' : 'skills'}/${e._id.slice(2)}`;
      return (
        <div
          class="vyb-card"
          data-id={e._id}
          data-type={e._type}
          data-stars={e.stars ?? -1}
          data-delta={e.delta7d ?? 0}
          data-hot={computeHotScore(e).toFixed(4)}
          data-added={e.data.addedAt}
          data-name={e.data.name.toLowerCase()}
          data-tags={(e.data.tags ?? []).map((t: string) => t.toLowerCase()).join('|')}
          data-installable={e._type === 'skill' && e.data.install ? 'yes' : 'no'}
        >
          <Card
            name={e.data.name}
            tagline={e.data.tagline}
            href={detailHref}
            url={e.data.url}
            github={e.data.github}
            author={e.data.author}
            tags={e.data.tags ?? []}
            stars={e.stars}
            delta7d={e.delta7d}
            badge={e.badge}
            featured={e.data.featured}
            entryType={e._type}
            entrySlug={e._id.slice(2)}
          />
        </div>
      );
    })}
  </div>

  <p id="vyb-empty" class="hidden text-center text-[var(--color-fg-muted)] py-16">
    No matches. Try a different search.
  </p>
</section>

<script type="application/json" id="vyb-data" set:html={JSON.stringify(searchIndex)} />

<script>
  import Fuse from 'fuse.js';

  const root = document.querySelector('.vyb-search') as HTMLElement | null;
  const dataNode = document.getElementById('vyb-data');
  if (!root || !dataNode) {
    // No-op if the component didn't render
  } else {
    const data = JSON.parse(dataNode.textContent || '[]');
    const fuse = new Fuse(data, {
      keys: [
        { name: 'n', weight: 2 },
        { name: 't', weight: 1 },
        { name: 'tags', weight: 1.5 },
        { name: 'bw', weight: 1 },
        { name: 'author', weight: 0.5 },
      ],
      threshold: 0.4,
      ignoreLocation: true,
      minMatchCharLength: 2,
    });

    const grid = document.getElementById('vyb-grid')!;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.vyb-card'));
    const countEl = document.getElementById('vyb-count')!;
    const emptyEl = document.getElementById('vyb-empty')!;

    let activeType: 'all' | 'project' | 'skill' =
      (root.dataset.defaultType as any) || 'all';
    const activeTags = new Set<string>();
    let activeSort: 'stars' | 'hot' | 'rising' | 'recent' | 'alpha' = 'stars';
    let activeQuery = '';

    function setActive(group: string, value: string) {
      root.querySelectorAll<HTMLElement>(`.${group} button`).forEach((btn) => {
        const v = (btn.dataset[group.replace('vyb-', '')] || '') as string;
        const isActive = v === value;
        btn.dataset.active = isActive ? 'true' : 'false';
        if (isActive) {
          btn.classList.add('bg-[var(--color-bg)]', 'text-[var(--color-fg)]', 'font-medium');
          btn.classList.remove('text-[var(--color-fg-muted)]');
        } else {
          btn.classList.remove('bg-[var(--color-bg)]', 'text-[var(--color-fg)]', 'font-medium');
          btn.classList.add('text-[var(--color-fg-muted)]');
        }
      });
    }

    function applySort() {
      const visible = cards.filter((c) => !c.hidden);
      visible.sort((a, b) => {
        const sa = +a.dataset.stars!, sb = +b.dataset.stars!;
        const da = +a.dataset.delta!, db = +b.dataset.delta!;
        const ha = +a.dataset.hot!, hb = +b.dataset.hot!;
        const aa = a.dataset.added!, ab = b.dataset.added!;
        const na = a.dataset.name!, nb = b.dataset.name!;
        switch (activeSort) {
          case 'stars': return sb - sa;
          case 'hot': return hb - ha || db - da || sb - sa;
          case 'rising': return db - da || sb - sa;
          case 'recent': return ab.localeCompare(aa) || sb - sa;
          case 'alpha': return na.localeCompare(nb);
        }
      });
      visible.forEach((c) => grid.appendChild(c));
    }

    function applyFilter() {
      let allowed: Set<string> | null = null;
      if (activeQuery.trim().length >= 2) {
        const matches = fuse.search(activeQuery.trim());
        allowed = new Set(matches.map((m: any) => m.item.i));
      }

      let count = 0;
      for (const card of cards) {
        const id = card.dataset.id!;
        const t = card.dataset.type!;
        const tags = (card.dataset.tags || '').split('|').filter(Boolean);

        let visible = allowed === null ? true : allowed.has(id);
        if (activeType !== 'all' && t !== activeType) visible = false;
        // Skills filter additionally narrows to entries with an install command
        if (activeType === 'skill' && card.dataset.installable !== 'yes') visible = false;
        if (activeTags.size > 0) {
          for (const wanted of activeTags) {
            if (!tags.includes(wanted)) {
              visible = false;
              break;
            }
          }
        }

        card.hidden = !visible;
        if (visible) count++;
      }

      countEl.textContent = String(count);
      emptyEl.classList.toggle('hidden', count > 0);
      applySort();
    }

    // Search input
    const input = document.getElementById('vyb-q') as HTMLInputElement | null;
    input?.addEventListener('input', (e) => {
      activeQuery = (e.target as HTMLInputElement).value;
      applyFilter();
    });

    // Type pills
    root.querySelectorAll<HTMLButtonElement>('.vyb-type button').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeType = btn.dataset.type as any;
        setActive('vyb-type', activeType);
        applyFilter();
      });
    });

    // Sort pills
    root.querySelectorAll<HTMLButtonElement>('.vyb-sort button').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeSort = btn.dataset.sort as any;
        setActive('vyb-sort', activeSort);
        applyFilter();
      });
    });

    // Tag chips
    root.querySelectorAll<HTMLButtonElement>('.vyb-tags button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.tag!;
        if (activeTags.has(t)) {
          activeTags.delete(t);
          btn.classList.remove('bg-[var(--color-accent-soft)]', 'text-[var(--color-accent)]', 'border-[var(--color-accent)]/40');
          btn.classList.add('bg-[var(--color-card)]', 'text-[var(--color-fg-muted)]', 'border-[var(--color-border)]');
        } else {
          activeTags.add(t);
          btn.classList.add('bg-[var(--color-accent-soft)]', 'text-[var(--color-accent)]', 'border-[var(--color-accent)]/40');
          btn.classList.remove('bg-[var(--color-card)]', 'text-[var(--color-fg-muted)]', 'border-[var(--color-border)]');
        }
        applyFilter();
      });
    });

    // Keyboard shortcut: '/' focuses search
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
        e.preventDefault();
        input?.focus();
      }
    });

    // Initial active state
    setActive('vyb-type', activeType);
    setActive('vyb-sort', activeSort);

    // Auto-focus search if arrived via ?search=1
    if (new URLSearchParams(window.location.search).has('search')) {
      input?.focus();
      history.replaceState(null, '', window.location.pathname);
    }
  }
</script>
