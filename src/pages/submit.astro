---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Submit · vybify" description="Submit a vibe-coded project or skill to vybify.">
  <a href="/" class="inline-flex items-center gap-1.5 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition mb-6">
    <span aria-hidden="true">←</span> Back
  </a>

  <section class="max-w-3xl">
    <h1 class="text-2xl sm:text-3xl font-semibold mb-2">Submit a project or skill</h1>
    <p class="text-[var(--color-fg-muted)] mb-8 text-lg">
      Built something with AI tools? Made a skill, MCP server, or rule pack worth sharing?
    </p>

    <div class="grid md:grid-cols-2 gap-4">
      <div class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-5">
        <h2 class="text-base font-semibold mb-2">By email</h2>
        <p class="text-sm text-[var(--color-fg-muted)] mb-3">
          Send to <a href="mailto:hello@vybify.com?subject=Submission" class="text-[var(--color-accent)] hover:underline">hello@vybify.com</a>:
        </p>
        <ul class="text-sm space-y-1.5 text-[var(--color-fg-muted)] list-disc list-inside">
          <li>Name + one-line tagline</li>
          <li>Live URL</li>
          <li>GitHub repo (recommended)</li>
          <li>3–5 tags</li>
          <li>What you built it with</li>
        </ul>
      </div>

      <div class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-5">
        <h2 class="text-base font-semibold mb-2">Open a pull request</h2>
        <p class="text-sm text-[var(--color-fg-muted)] mb-3">
          Add a JSON file to the
          <a href="https://github.com/jakemellman/vybify" class="text-[var(--color-accent)] hover:underline">repo</a>
          under <code class="font-mono text-xs px-1 py-0.5 rounded bg-[var(--color-bg)]">src/content/projects/</code>
          or <code class="font-mono text-xs px-1 py-0.5 rounded bg-[var(--color-bg)]">src/content/skills/</code>:
        </p>
        <pre class="text-xs font-mono bg-[var(--color-bg)] border border-[var(--color-border)] rounded p-3 overflow-x-auto"><code>{`{
  "name": "Your project",
  "tagline": "One short sentence.",
  "url": "https://example.com",
  "github": "owner/repo",
  "author": "You",
  "tags": ["ai", "indie"],
  "builtWith": ["Claude Code"],
  "addedAt": "2026-04-29"
}`}</code></pre>
      </div>
    </div>
  </section>
</Layout>
