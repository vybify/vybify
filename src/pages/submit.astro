---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login?redirect=/submit');
}

let success = false;
let formError: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const type = String(form.get('type') ?? 'project');
  const name = String(form.get('name') ?? '').trim();
  const tagline = String(form.get('tagline') ?? '').trim();
  const url = String(form.get('url') ?? '').trim();
  const github = String(form.get('github') ?? '').trim() || null;
  const tagsRaw = String(form.get('tags') ?? '').trim();
  const tags = tagsRaw ? tagsRaw.split(',').map((t: string) => t.trim()).filter(Boolean) : [];
  const body = String(form.get('body') ?? '').trim() || null;

  // project-specific
  const builtWithRaw = String(form.get('built_with') ?? '').trim();
  const builtWith = builtWithRaw ? builtWithRaw.split(',').map((t: string) => t.trim()).filter(Boolean) : [];

  // skill-specific
  const kind = type === 'skill' ? String(form.get('kind') ?? 'other') : null;
  const install = type === 'skill' ? (String(form.get('install') ?? '').trim() || null) : null;

  if (!name || !tagline || !url) {
    formError = 'Name, tagline, and URL are required.';
  } else if (tagline.length > 160) {
    formError = 'Tagline must be 160 characters or fewer.';
  } else {
    const { error } = await Astro.locals.supabase
      .from('submissions')
      .insert({
        user_id: user.id,
        type,
        name,
        tagline,
        url,
        github,
        tags,
        body,
        built_with: builtWith,
        kind,
        install,
      });

    if (error) {
      formError = error.message;
    } else {
      success = true;
    }
  }
}
---

<Layout title="Submit · vybify" description="Submit a project or skill to vybify.">
  <a href="/" class="inline-flex items-center gap-1.5 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition mb-6">
    <span aria-hidden="true">&larr;</span> Back
  </a>

  <section class="max-w-xl">
    {success ? (
      <div class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-6 text-center">
        <h1 class="text-2xl font-semibold mb-2">Submitted!</h1>
        <p class="text-[var(--color-fg-muted)] mb-4">We'll review your submission shortly.</p>
        <div class="flex justify-center gap-3">
          <a href="/submit" class="px-4 py-2 rounded-md bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition">
            Submit another
          </a>
          <a href="/my-submissions" class="px-4 py-2 rounded-md border border-[var(--color-border)] text-sm font-medium hover:bg-[var(--color-bg)] transition">
            My submissions
          </a>
        </div>
      </div>
    ) : (
      <>
        <h1 class="text-2xl sm:text-3xl font-semibold mb-2">Submit a project or skill</h1>
        <p class="text-[var(--color-fg-muted)] mb-6">
          Paste a GitHub repo URL to auto-fill, then tweak as needed.
        </p>

        <!-- GitHub auto-fill bar -->
        <div class="flex gap-2 mb-6">
          <input
            id="github-url-input"
            type="text"
            placeholder="https://github.com/owner/repo"
            class="flex-1 px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]"
          />
          <button
            id="github-fetch-btn"
            type="button"
            class="px-4 py-2 rounded-md bg-[var(--color-fg)] text-white text-sm font-medium hover:opacity-90 transition whitespace-nowrap"
          >
            Auto-fill
          </button>
        </div>
        <p id="github-fetch-error" class="text-sm text-red-600 -mt-4 mb-4 hidden"></p>

        {formError && (
          <p class="text-sm text-red-600 mb-4">{formError}</p>
        )}

        <form method="POST" class="flex flex-col gap-4">
          <!-- Type toggle -->
          <fieldset class="flex gap-2">
            <label class="flex-1">
              <input type="radio" name="type" value="project" checked class="peer sr-only" />
              <div class="peer-checked:bg-[var(--color-accent-soft)] peer-checked:text-[var(--color-accent)] peer-checked:border-[var(--color-accent)] text-center py-2 rounded-md border border-[var(--color-border)] text-sm font-medium cursor-pointer transition hover:bg-[var(--color-bg)]">
                Project
              </div>
            </label>
            <label class="flex-1">
              <input type="radio" name="type" value="skill" class="peer sr-only" />
              <div class="peer-checked:bg-[var(--color-accent-soft)] peer-checked:text-[var(--color-accent)] peer-checked:border-[var(--color-accent)] text-center py-2 rounded-md border border-[var(--color-border)] text-sm font-medium cursor-pointer transition hover:bg-[var(--color-bg)]">
                Skill
              </div>
            </label>
          </fieldset>

          <!-- Common fields -->
          <div>
            <label for="name" class="text-sm font-medium">Name</label>
            <input id="name" name="name" type="text" required class="mt-1 w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
          </div>

          <div>
            <label for="tagline" class="text-sm font-medium">Tagline</label>
            <input id="tagline" name="tagline" type="text" required maxlength="160" class="mt-1 w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
            <p class="text-xs text-[var(--color-fg-muted)] mt-1"><span id="tagline-count">0</span>/160</p>
          </div>

          <div>
            <label for="url" class="text-sm font-medium">URL</label>
            <input id="url" name="url" type="url" required placeholder="https://..." class="mt-1 w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
          </div>

          <div>
            <label for="github" class="text-sm font-medium">GitHub repo</label>
            <input id="github" name="github" type="text" placeholder="owner/repo" class="mt-1 w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
          </div>

          <div>
            <label for="tags" class="text-sm font-medium">Tags</label>
            <input id="tags" name="tags" type="text" placeholder="ai, cli, productivity" class="mt-1 w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
            <p class="text-xs text-[var(--color-fg-muted)] mt-1">Comma-separated</p>
          </div>

          <!-- Project-specific: built_with -->
          <div id="project-fields">
            <label for="built_with" class="text-sm font-medium">Built with</label>
            <input id="built_with" name="built_with" type="text" placeholder="Claude Code, Cursor, v0" class="mt-1 w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
            <p class="text-xs text-[var(--color-fg-muted)] mt-1">Comma-separated AI tools used</p>
          </div>

          <!-- Skill-specific: kind + install -->
          <div id="skill-fields" class="hidden">
            <div class="mb-4">
              <label for="kind" class="text-sm font-medium">Kind</label>
              <select id="kind" name="kind" class="mt-1 w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]">
                <option value="claude-code-skill">Claude Code skill</option>
                <option value="mcp-server">MCP server</option>
                <option value="cursor-rule">Cursor rule</option>
                <option value="custom-gpt">Custom GPT</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="install" class="text-sm font-medium">Install command</label>
              <input id="install" name="install" type="text" placeholder="npx some-package" class="mt-1 w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
            </div>
          </div>

          <div>
            <label for="body" class="text-sm font-medium">Description <span class="font-normal text-[var(--color-fg-muted)]">(optional, markdown)</span></label>
            <textarea id="body" name="body" rows="5" class="mt-1 w-full px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] resize-y"></textarea>
          </div>

          <button
            type="submit"
            class="px-4 py-2.5 rounded-md bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition"
          >
            Submit for review
          </button>
        </form>
      </>
    )}
  </section>

  <script>
    // Type toggle: show/hide project vs skill fields
    const typeRadios = document.querySelectorAll<HTMLInputElement>('input[name="type"]');
    const projectFields = document.getElementById('project-fields');
    const skillFields = document.getElementById('skill-fields');

    typeRadios.forEach((r) =>
      r.addEventListener('change', () => {
        const isSkill = (document.querySelector<HTMLInputElement>('input[name="type"]:checked'))?.value === 'skill';
        projectFields?.classList.toggle('hidden', isSkill);
        skillFields?.classList.toggle('hidden', !isSkill);
      }),
    );

    // Tagline counter
    const taglineInput = document.getElementById('tagline') as HTMLInputElement | null;
    const taglineCount = document.getElementById('tagline-count');
    taglineInput?.addEventListener('input', () => {
      if (taglineCount) taglineCount.textContent = String(taglineInput.value.length);
    });

    // GitHub auto-fill
    const ghInput = document.getElementById('github-url-input') as HTMLInputElement;
    const ghBtn = document.getElementById('github-fetch-btn') as HTMLButtonElement;
    const ghError = document.getElementById('github-fetch-error') as HTMLElement;

    function parseGitHubRepo(input: string): string | null {
      const trimmed = input.trim();
      // owner/repo
      if (/^[\w.-]+\/[\w.-]+$/.test(trimmed)) return trimmed;
      // full URL
      try {
        const url = new URL(trimmed);
        if (url.hostname === 'github.com' || url.hostname === 'www.github.com') {
          const parts = url.pathname.split('/').filter(Boolean);
          if (parts.length >= 2) return `${parts[0]}/${parts[1]}`;
        }
      } catch {}
      return null;
    }

    ghBtn?.addEventListener('click', async () => {
      const repo = parseGitHubRepo(ghInput.value);
      if (!repo) {
        ghError.textContent = 'Enter a GitHub URL or owner/repo.';
        ghError.classList.remove('hidden');
        return;
      }
      ghError.classList.add('hidden');
      ghBtn.textContent = 'Fetching...';
      ghBtn.disabled = true;

      try {
        const res = await fetch(`/api/github-repo?repo=${encodeURIComponent(repo)}`);
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || `HTTP ${res.status}`);
        }
        const data = await res.json();

        // Fill form fields
        const nameInput = document.getElementById('name') as HTMLInputElement;
        const taglineInput = document.getElementById('tagline') as HTMLInputElement;
        const urlInput = document.getElementById('url') as HTMLInputElement;
        const githubInput = document.getElementById('github') as HTMLInputElement;
        const tagsInput = document.getElementById('tags') as HTMLInputElement;
        const bodyInput = document.getElementById('body') as HTMLTextAreaElement;
        const builtWithInput = document.getElementById('built_with') as HTMLInputElement;
        const kindSelect = document.getElementById('kind') as HTMLSelectElement;
        const installInput = document.getElementById('install') as HTMLInputElement;

        if (nameInput && !nameInput.value) nameInput.value = data.name;
        if (taglineInput && !taglineInput.value) {
          taglineInput.value = data.tagline || '';
          if (taglineCount) taglineCount.textContent = String(taglineInput.value.length);
        }
        if (urlInput && !urlInput.value) urlInput.value = data.homepage || data.html_url;
        if (githubInput) githubInput.value = repo;
        if (tagsInput && !tagsInput.value && data.topics?.length) {
          tagsInput.value = data.topics.join(', ');
        }
        if (bodyInput && !bodyInput.value && data.body) {
          bodyInput.value = data.body;
        }
        if (builtWithInput && !builtWithInput.value && data.builtWith?.length) {
          builtWithInput.value = data.builtWith.join(', ');
        }
        if (installInput && !installInput.value && data.install) {
          installInput.value = data.install;
        }

        // Auto-select type and kind based on repo content
        if (data.inferredType) {
          const typeRadio = document.querySelector<HTMLInputElement>(`input[name="type"][value="${data.inferredType}"]`);
          if (typeRadio) {
            typeRadio.checked = true;
            typeRadio.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }
        if (kindSelect && data.kind) {
          kindSelect.value = data.kind;
        }
      } catch (err: any) {
        ghError.textContent = err.message || 'Failed to fetch repo info.';
        ghError.classList.remove('hidden');
      } finally {
        ghBtn.textContent = 'Auto-fill';
        ghBtn.disabled = false;
      }
    });

    // Also trigger on Enter in the GitHub URL input
    ghInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        ghBtn?.click();
      }
    });
  </script>
</Layout>
