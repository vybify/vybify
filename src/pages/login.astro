---
import Layout from '../layouts/Layout.astro';

const isPopup = Astro.url.searchParams.get('popup') === '1';

if (Astro.locals.user) {
  if (isPopup) {
    // Already logged in and opened as popup — notify opener and close
    return new Response(`<script>window.opener?.postMessage('auth-complete','*');window.close();</script>`, {
      headers: { 'Content-Type': 'text/html' },
    });
  }
  return Astro.redirect('/');
}

let magicLinkMsg: string | null = null;
let magicLinkErr: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = String(form.get('email') ?? '').trim();
  if (!email) {
    magicLinkErr = 'Enter an email.';
  } else {
    const origin = new URL(Astro.request.url).origin;
    const { error } = await Astro.locals.supabase.auth.signInWithOtp({
      email,
      options: { emailRedirectTo: `${origin}/auth/callback` },
    });
    if (error) magicLinkErr = error.message;
    else magicLinkMsg = `Check ${email} for a sign-in link.`;
  }
}
---

<Layout title="Sign in · vybify" description="Sign in to vybify.">
  <div class="mx-auto max-w-sm py-12">
    <h1 class="text-2xl font-semibold tracking-tight mb-2">Sign in to vybify</h1>
    <p class="text-sm text-[var(--color-fg-muted)] mb-8">
      Sign in to submit projects, vote, and enter competitions.
    </p>

    <button
      id="github-signin"
      type="button"
      class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-md border border-[var(--color-border)] bg-[var(--color-fg)] text-white hover:bg-[var(--color-fg-soft)] transition text-sm font-medium"
    >
      <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      Continue with GitHub
    </button>

    <button
      id="google-signin"
      type="button"
      class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] hover:bg-[var(--color-bg)] transition text-sm font-medium mt-2"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="#4285F4" d="M23.49 12.27c0-.79-.07-1.54-.19-2.27H12v4.51h6.44c-.28 1.5-1.13 2.77-2.41 3.62v3.01h3.89c2.27-2.09 3.57-5.18 3.57-8.87z"/>
        <path fill="#34A853" d="M12 24c3.24 0 5.96-1.07 7.94-2.91l-3.89-3.01c-1.08.72-2.45 1.16-4.05 1.16-3.12 0-5.76-2.1-6.71-4.94H1.27v3.1C3.25 21.3 7.31 24 12 24z"/>
        <path fill="#FBBC05" d="M5.29 14.3c-.24-.72-.38-1.49-.38-2.3s.14-1.58.38-2.3v-3.1H1.27C.46 8.21 0 10.05 0 12s.46 3.79 1.27 5.4l4.02-3.1z"/>
        <path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.45-3.45C17.95 1.19 15.24 0 12 0 7.31 0 3.25 2.7 1.27 6.6l4.02 3.1C6.24 6.85 8.88 4.75 12 4.75z"/>
      </svg>
      Continue with Google
    </button>

    <div class="my-6 flex items-center gap-3 text-xs text-[var(--color-fg-muted)]">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <span>or</span>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <form method="POST" class="flex flex-col gap-3">
      <label class="text-sm font-medium" for="email">Email magic link</label>
      <input
        id="email"
        name="email"
        type="email"
        required
        placeholder="you@example.com"
        class="px-3 py-2 rounded-md border border-[var(--color-border)] bg-[var(--color-card)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]"
      />
      <button
        type="submit"
        class="px-4 py-2.5 rounded-md bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition"
      >
        Send magic link
      </button>
      {magicLinkMsg && (
        <p class="text-sm text-[var(--color-positive)]">{magicLinkMsg}</p>
      )}
      {magicLinkErr && (
        <p class="text-sm text-red-600">{magicLinkErr}</p>
      )}
    </form>
  </div>

  <script>
    import { createSupabaseBrowserClient } from '../lib/supabase';
    const supabase = createSupabaseBrowserClient();
    const params = new URLSearchParams(window.location.search);
    const isPopup = params.get('popup') === '1';
    const callbackUrl = isPopup
      ? `${window.location.origin}/auth/callback?popup=1`
      : `${window.location.origin}/auth/callback`;

    document.getElementById('github-signin')?.addEventListener('click', async () => {
      await supabase.auth.signInWithOAuth({
        provider: 'github',
        options: { redirectTo: callbackUrl },
      });
    });

    document.getElementById('google-signin')?.addEventListener('click', async () => {
      await supabase.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo: callbackUrl },
      });
    });
  </script>
</Layout>
