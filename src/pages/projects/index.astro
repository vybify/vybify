---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import SearchableGrid from '../../components/SearchableGrid.astro';
---

<Layout title="Projects · vybify">
  <section class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-semibold text-[var(--color-fg)] mb-1">Projects</h1>
    <p class="text-[var(--color-fg-muted)]">Vibe-coded apps, agents, and tools — ranked by GitHub stars.</p>
  </section>

  <SearchableGrid type="project" />
</Layout>
