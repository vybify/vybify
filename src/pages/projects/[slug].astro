---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import UpvoteScript from '../../components/UpvoteScript.astro';
import { withStars, formatStars, formatDelta } from '../../lib/github';

export async function getStaticPaths() {
  const allProjects = await withStars(await getCollection('projects'));
  const allSkills = await withStars(await getCollection('skills'));

  return allProjects.map((entry) => ({
    params: { slug: entry.id },
    props: {
      entry,
      siblings: allProjects.filter((e) => e.id !== entry.id),
      otherType: allSkills,
    },
  }));
}

const { entry, siblings, otherType } = Astro.props;
const { data, stars, delta7d } = entry;
const hasBody = !!entry.body?.trim();
const { Content } = hasBody ? await render(entry) : { Content: null };

const tagSet = new Set(data.tags.map((t: string) => t.toLowerCase()));
const related = [...siblings, ...otherType]
  .map((e) => ({
    e,
    overlap: (e.data.tags as string[]).filter((t) => tagSet.has(t.toLowerCase())).length,
  }))
  .filter((x) => x.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || (b.e.stars ?? -1) - (a.e.stars ?? -1))
  .slice(0, 4)
  .map((x) => x.e);

const deltaStr = formatDelta(delta7d);
---

<Layout title={`${data.name} · vybify`} description={data.tagline}>
  <a href="/projects" class="inline-flex items-center gap-1.5 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition mb-6">
    <span aria-hidden="true">←</span> All projects
  </a>

  <article class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-6 sm:p-8 mb-8">
    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="label">Project</span>
        {data.featured && (
          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium uppercase tracking-wide bg-yellow-50 text-yellow-700 border border-yellow-200">
            Featured
          </span>
        )}
      </div>

      <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight mb-2">{data.name}</h1>
      <p class="text-lg text-[var(--color-fg-muted)] max-w-2xl leading-relaxed">{data.tagline}</p>

      <div class="flex gap-2 mt-5">
        <a
          href={data.url}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-1.5 px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition flex-1 sm:flex-none"
        >
          Open
          <span aria-hidden="true">↗</span>
        </a>
        {data.github && (
          <a
            href={`https://github.com/${data.github}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-1.5 px-5 py-2.5 rounded-lg bg-[var(--color-card)] border border-[var(--color-border)] text-sm font-medium text-[var(--color-fg)] hover:border-[var(--color-border-strong)] transition flex-1 sm:flex-none"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            GitHub
          </a>
        )}
      </div>
    </div>

    <hr class="border-[var(--color-border)] my-6" />

    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-x-6 gap-y-4">
      <div>
        <dt class="label mb-1">Stars</dt>
        <dd class="text-lg font-medium tnum">
          {formatStars(stars)}
          {deltaStr && (
            <span class="text-sm text-[var(--color-positive)] ml-1.5 font-normal">{deltaStr}</span>
          )}
        </dd>
      </div>
      <div>
        <dt class="label mb-1">Upvotes</dt>
        <dd>
          <button
            type="button"
            class="vyb-upvote inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-sm border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-fg-muted)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition"
            data-entry-type="project"
            data-entry-slug={entry.id}
            aria-label="Upvote this project"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="vyb-upvote-icon" aria-hidden="true">
              <path d="M12 19V5M5 12l7-7 7 7" />
            </svg>
            <span class="vyb-upvote-count tnum font-medium">0</span>
          </button>
        </dd>
      </div>
      {data.author && (
        <div>
          <dt class="label mb-1">Author</dt>
          <dd class="text-sm">{data.author}</dd>
        </div>
      )}
      {data.builtWith && data.builtWith.length > 0 && (
        <div>
          <dt class="label mb-1">Built with</dt>
          <dd class="text-sm">{data.builtWith.join(', ')}</dd>
        </div>
      )}
      <div>
        <dt class="label mb-1">Added</dt>
        <dd class="text-sm tnum text-[var(--color-fg-muted)]">{data.addedAt}</dd>
      </div>
    </dl>

    <hr class="border-[var(--color-border)] my-6" />

    <div class="flex flex-wrap gap-1.5">
      {data.tags.map((tag: string) => (
        <a
          href={`/tag/${encodeURIComponent(tag.toLowerCase())}`}
          class="inline-flex items-center px-2.5 py-1 rounded-full text-xs bg-[var(--color-bg)] text-[var(--color-fg-muted)] hover:bg-[var(--color-accent-soft)] hover:text-[var(--color-accent)] transition"
        >
          #{tag}
        </a>
      ))}
    </div>
  </article>

  {hasBody && Content && (
    <section class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-6 sm:p-8 mb-8">
      <h2 class="text-base font-semibold text-[var(--color-fg-muted)] uppercase tracking-wider mb-4">
        How it was built
      </h2>
      <div class="prose">
        <Content />
      </div>
    </section>
  )}

  {related.length > 0 && (
    <section>
      <h2 class="text-lg font-semibold mb-3">Related</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
        {related.map((r) => (
          <Card
            name={r.data.name}
            tagline={r.data.tagline}
            href={`/${'kind' in r.data ? 'skills' : 'projects'}/${r.id}`}
            url={r.data.url}
            github={r.data.github}
            author={r.data.author}
            tags={r.data.tags ?? []}
            stars={r.stars}
            delta7d={r.delta7d}
            badge={'kind' in r.data ? (
              r.data.kind === 'mcp-server' ? 'MCP' :
              r.data.kind === 'claude-code-skill' ? 'Skill' :
              r.data.kind === 'cursor-rule' ? 'Cursor' : undefined
            ) : undefined}
            featured={r.data.featured}
            entryType={'kind' in r.data ? 'skill' : 'project'}
            entrySlug={r.id}
          />
        ))}
      </div>
    </section>
  )}
  <UpvoteScript />
</Layout>
