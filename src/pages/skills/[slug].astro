---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import CopyableCommand from '../../components/CopyableCommand.astro';
import { withStars, formatStars, formatDelta } from '../../lib/github';

export async function getStaticPaths() {
  const allSkills = await withStars(await getCollection('skills'));
  const allProjects = await withStars(await getCollection('projects'));

  return allSkills.map((entry) => ({
    params: { slug: entry.id },
    props: {
      entry,
      siblings: allSkills.filter((e) => e.id !== entry.id),
      otherType: allProjects,
    },
  }));
}

const { entry, siblings, otherType } = Astro.props;
const { data, stars, delta7d } = entry;

const tagSet = new Set(data.tags.map((t: string) => t.toLowerCase()));
const related = [...siblings, ...otherType]
  .map((e) => ({
    e,
    overlap: (e.data.tags as string[]).filter((t) => tagSet.has(t.toLowerCase())).length,
  }))
  .filter((x) => x.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || (b.e.stars ?? -1) - (a.e.stars ?? -1))
  .slice(0, 4)
  .map((x) => x.e);

const deltaStr = formatDelta(delta7d);
const description = data.tagline;

const kindLabel: Record<string, string> = {
  'claude-code-skill': 'Claude Code skill',
  'mcp-server': 'MCP server',
  'cursor-rule': 'Cursor rules',
  'custom-gpt': 'Custom GPT',
  other: 'Skill',
};
---

<Layout title={`${data.name} · vybify`} description={description}>
  <a href="/skills" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition inline-flex items-center gap-1 mb-8">
    <span aria-hidden="true">←</span> All skills
  </a>

  <article class="max-w-3xl">
    <header class="mb-10">
      <div class="flex items-center gap-3 text-xs uppercase tracking-widest text-[var(--color-fg-muted)] mb-3">
        <span>{kindLabel[data.kind] ?? 'Skill'}</span>
        {data.featured && (
          <span class="text-[var(--color-accent-2)]">· Featured</span>
        )}
      </div>

      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">{data.name}</h1>
      <p class="text-xl text-[var(--color-fg-muted)] leading-relaxed mb-8">{data.tagline}</p>

      {data.install && (
        <div class="mb-6">
          <CopyableCommand command={data.install} label="Install" />
        </div>
      )}

      <div class="flex flex-wrap gap-3">
        <a
          href={data.url}
          target="_blank"
          rel="noopener"
          class={`inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition ${data.install ? 'bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)]/60' : 'bg-[var(--color-accent)] text-[#0a0a0f] hover:opacity-90'}`}
        >
          Open {data.name}
          <span aria-hidden="true">↗</span>
        </a>
        {data.github && (
          <a
            href={`https://github.com/${data.github}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-accent)]/60 transition"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            View on GitHub
          </a>
        )}
      </div>
    </header>

    <section class="grid sm:grid-cols-2 gap-4 mb-10">
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
        <div class="text-xs uppercase tracking-widest text-[var(--color-fg-muted)] mb-1">Stars</div>
        <div class="font-mono text-2xl">
          {formatStars(stars)}
          {deltaStr && (
            <span class="text-base text-[var(--color-accent-2)] ml-2">{deltaStr} (7d)</span>
          )}
        </div>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
        <div class="text-xs uppercase tracking-widest text-[var(--color-fg-muted)] mb-1">Type</div>
        <div class="font-medium">{kindLabel[data.kind] ?? 'Skill'}</div>
      </div>
      {data.author && (
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
          <div class="text-xs uppercase tracking-widest text-[var(--color-fg-muted)] mb-1">Author</div>
          <div class="font-medium">{data.author}</div>
        </div>
      )}
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
        <div class="text-xs uppercase tracking-widest text-[var(--color-fg-muted)] mb-1">Added</div>
        <div class="font-medium font-mono">{data.addedAt}</div>
      </div>
    </section>

    <section class="mb-12">
      <div class="text-xs uppercase tracking-widest text-[var(--color-fg-muted)] mb-3">Tags</div>
      <div class="flex flex-wrap gap-2">
        {data.tags.map((tag: string) => (
          <a
            href={`/tag/${encodeURIComponent(tag.toLowerCase())}`}
            class="px-2.5 py-1 rounded-full text-sm border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:border-[var(--color-accent)]/60 hover:text-[var(--color-accent)] transition"
          >
            #{tag}
          </a>
        ))}
      </div>
    </section>
  </article>

  {related.length > 0 && (
    <section class="border-t border-[var(--color-border)] pt-10 mt-10">
      <h2 class="text-xl font-semibold mb-6">Related</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {related.map((r) => (
          <Card
            name={r.data.name}
            tagline={r.data.tagline}
            href={`/${'kind' in r.data ? 'skills' : 'projects'}/${r.id}`}
            url={r.data.url}
            github={r.data.github}
            author={r.data.author}
            tags={r.data.tags ?? []}
            stars={r.stars}
            delta7d={r.delta7d}
            badge={'kind' in r.data ? (
              r.data.kind === 'mcp-server' ? 'MCP' :
              r.data.kind === 'claude-code-skill' ? 'Skill' :
              r.data.kind === 'cursor-rule' ? 'Cursor' : undefined
            ) : undefined}
            featured={r.data.featured}
          />
        ))}
      </div>
    </section>
  )}
</Layout>
