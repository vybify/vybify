---
import Layout from '../../layouts/Layout.astro';

const ADMIN_EMAILS = ['jake@drinkpsilly.com'];

const user = Astro.locals.user;
if (!user || !ADMIN_EMAILS.includes(user.email ?? '')) {
  return Astro.redirect('/');
}

let actionMsg: string | null = null;
let actionErr: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action'));
  const id = String(form.get('id'));
  const reviewerNote = String(form.get('reviewer_note') ?? '').trim() || null;

  if ((action === 'approve' || action === 'reject') && id) {
    const status = action === 'approve' ? 'approved' : 'rejected';
    const { error } = await Astro.locals.supabase
      .from('claims')
      .update({ status, reviewer_note: reviewerNote })
      .eq('id', id);

    if (error) actionErr = error.message;
    else actionMsg = `Claim ${status}.`;
  } else if (action === 'delete' && id) {
    const { error } = await Astro.locals.supabase
      .from('claims')
      .delete()
      .eq('id', id);

    if (error) actionErr = error.message;
    else actionMsg = 'Claim deleted.';
  }
}

const statusFilter = Astro.url.searchParams.get('status') || 'pending';

const query = Astro.locals.supabase
  .from('claims')
  .select('*, profiles(display_name, handle, github_username, avatar_url)')
  .order('created_at', { ascending: false });

if (statusFilter !== 'all') {
  query.eq('status', statusFilter);
}

const { data: claims } = await query;

const statusColors: Record<string, string> = {
  pending: 'bg-yellow-100 text-yellow-800',
  approved: 'bg-green-100 text-green-800',
  rejected: 'bg-red-100 text-red-800',
};

const pendingCount = claims?.filter((c: any) => c.status === 'pending').length ?? 0;
---

<Layout title="Admin · Claims" description="Review ownership claims.">
  <a href="/" class="inline-flex items-center gap-1.5 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition mb-6">
    <span aria-hidden="true">&larr;</span> Back
  </a>

  <section class="max-w-3xl">
    <div class="flex items-center gap-4 mb-4">
      <h1 class="text-2xl font-semibold">Ownership Claims</h1>
      <a href="/admin/submissions" class="text-sm text-[var(--color-accent)] hover:underline">Submissions →</a>
    </div>

    {actionMsg && <p class="text-sm text-[var(--color-positive)] mb-4">{actionMsg}</p>}
    {actionErr && <p class="text-sm text-red-600 mb-4">{actionErr}</p>}

    <div class="flex gap-1 mb-6">
      {(['pending', 'approved', 'rejected', 'all'] as const).map((s) => (
        <a
          href={`/admin/claims?status=${s}`}
          class:list={[
            'px-3 py-1.5 rounded-md text-sm transition',
            statusFilter === s
              ? 'bg-[var(--color-accent-soft)] text-[var(--color-accent)] font-medium'
              : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg)]',
          ]}
        >
          {s.charAt(0).toUpperCase() + s.slice(1)}
          {s === 'pending' && pendingCount > 0 && (
            <span class="ml-1 inline-flex items-center justify-center px-1.5 py-0.5 rounded-full text-xs bg-yellow-100 text-yellow-800">
              {pendingCount}
            </span>
          )}
        </a>
      ))}
    </div>

    {!claims || claims.length === 0 ? (
      <div class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-8 text-center">
        <p class="text-[var(--color-fg-muted)]">No {statusFilter === 'all' ? '' : statusFilter} claims.</p>
      </div>
    ) : (
      <div class="flex flex-col gap-4">
        {claims.map((c: any) => (
          <div class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-5">
            <div class="flex items-start justify-between gap-3 mb-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h2 class="font-semibold">{c.entry_type}/{c.entry_slug}</h2>
                  <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[c.status] || ''}`}>
                    {c.status}
                  </span>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-xs text-[var(--color-fg-muted)] mb-3">
              <div>
                <span class="font-medium text-[var(--color-fg-soft)]">Claimant:</span>{' '}
                {c.profiles?.display_name || c.profiles?.handle || 'Unknown'}
              </div>
              <div>
                <span class="font-medium text-[var(--color-fg-soft)]">GitHub:</span>{' '}
                <a href={`https://github.com/${c.github_username}`} target="_blank" class="text-[var(--color-accent)] hover:underline">
                  @{c.github_username}
                </a>
              </div>
              <div>
                <span class="font-medium text-[var(--color-fg-soft)]">Entry:</span>{' '}
                <a href={`/${c.entry_type}s/${c.entry_slug}`} class="text-[var(--color-accent)] hover:underline">
                  View →
                </a>
              </div>
              <div>
                <span class="font-medium text-[var(--color-fg-soft)]">Date:</span>{' '}
                {new Date(c.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </div>
            </div>

            {c.status === 'pending' && (
              <div class="flex items-end gap-2 pt-3 border-t border-[var(--color-border)]">
                <form method="POST" class="flex items-end gap-2 flex-1">
                  <input type="hidden" name="id" value={c.id} />
                  <div class="flex-1">
                    <label class="text-xs text-[var(--color-fg-muted)]" for={`note-${c.id}`}>Note (optional)</label>
                    <input
                      id={`note-${c.id}`}
                      name="reviewer_note"
                      type="text"
                      placeholder="Reason..."
                      class="mt-0.5 w-full px-2 py-1.5 rounded-md border border-[var(--color-border)] bg-white text-xs focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]"
                    />
                  </div>
                  <button
                    type="submit"
                    name="action"
                    value="approve"
                    class="px-3 py-1.5 rounded-md bg-[var(--color-positive)] text-white text-xs font-medium hover:opacity-90 transition"
                  >
                    Approve
                  </button>
                  <button
                    type="submit"
                    name="action"
                    value="reject"
                    class="px-3 py-1.5 rounded-md bg-red-500 text-white text-xs font-medium hover:opacity-90 transition"
                  >
                    Reject
                  </button>
                </form>
                <form method="POST">
                  <input type="hidden" name="id" value={c.id} />
                  <button
                    type="submit"
                    name="action"
                    value="delete"
                    class="px-3 py-1.5 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)] hover:text-red-600 hover:border-red-300 transition"
                    onclick="return confirm('Delete this claim permanently?')"
                  >
                    Delete
                  </button>
                </form>
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>
