---
export const prerender = true;
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { withStars } from '../../lib/github';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const skills = await getCollection('skills');
  const tags = new Set<string>();
  for (const e of [...projects, ...skills]) {
    for (const t of e.data.tags) tags.add(t.toLowerCase());
  }
  return [...tags].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const projects = (await withStars(await getCollection('projects'))).map((e) => ({ ...e, _type: 'project' as const }));
const skills = (await withStars(await getCollection('skills'))).map((e) => ({ ...e, _type: 'skill' as const }));

const matches = [...projects, ...skills]
  .filter((e) => e.data.tags.map((t: string) => t.toLowerCase()).includes(tag!))
  .sort((a, b) => (b.stars ?? -1) - (a.stars ?? -1));

const kindBadge: Record<string, string | undefined> = {
  'mcp-server': 'MCP', 'claude-code-skill': 'Skill', 'cursor-rule': 'Cursor', 'custom-gpt': 'GPT', other: undefined,
};
const tagBadgeMap: [string[], string][] = [
  [['agent', 'autonomous'], 'Agent'], [['ide', 'editor', 'vscode', 'jetbrains'], 'IDE'],
  [['cli'], 'CLI'], [['framework', 'sdk', 'library'], 'Framework'],
  [['mcp'], 'MCP'], [['automation'], 'Automation'], [['browser'], 'Browser'],
];
function getBadge(entry: typeof matches[0]): string | undefined {
  if (entry._type === 'skill') return kindBadge[(entry.data as any).kind];
  const lower = new Set(entry.data.tags.map((t: string) => t.toLowerCase()));
  for (const [keys, label] of tagBadgeMap) {
    if (keys.some((k) => lower.has(k))) return label;
  }
  return undefined;
}
---

<Layout title={`#${tag} · vybify`}>
  <a href="/" class="inline-flex items-center gap-1.5 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition mb-6">
    <span aria-hidden="true">←</span> All
  </a>

  <section class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight mb-1">
      <span class="text-[var(--color-accent)]">#</span>{tag}
    </h1>
    <p class="text-[var(--color-fg-muted)]">
      <span class="tnum font-medium text-[var(--color-fg)]">{matches.length}</span>
      {matches.length === 1 ? 'entry' : 'entries'} tagged.
    </p>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
    {matches.map((entry) => (
      <Card
        name={entry.data.name}
        tagline={entry.data.tagline}
        href={`/${entry._type === 'project' ? 'projects' : 'skills'}/${entry.id}`}
        url={entry.data.url}
        github={entry.data.github}
        author={entry.data.author}
        tags={entry.data.tags}
        stars={entry.stars}
        delta7d={entry.delta7d}
        featured={entry.data.featured}
        badge={getBadge(entry)}
        entryType={entry._type}
        entrySlug={entry.id}
      />
    ))}
  </div>
</Layout>
