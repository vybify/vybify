---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { withStars } from '../lib/github';

const projects = await withStars(await getCollection('projects'));
projects.sort((a, b) => (b.stars ?? -1) - (a.stars ?? -1));
---

<Layout title="Projects · vybify">
  <section class="mb-10">
    <h1 class="text-4xl font-bold tracking-tight mb-2">All projects</h1>
    <p class="text-[var(--color-fg-muted)]">
      {projects.length} vibe-coded projects, ranked by GitHub stars.
    </p>
  </section>

  <div class="grid md:grid-cols-2 gap-4">
    {projects.map((entry, i) => (
      <Card
        rank={i + 1}
        name={entry.data.name}
        tagline={entry.data.tagline}
        url={entry.data.url}
        github={entry.data.github}
        author={entry.data.author}
        tags={entry.data.tags}
        stars={entry.stars}
        featured={entry.data.featured}
      />
    ))}
  </div>
</Layout>
