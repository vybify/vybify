---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SearchableGrid from '../components/SearchableGrid.astro';

const projects = await getCollection('projects');
const skills = await getCollection('skills');
---

<Layout>
  <section class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-semibold text-[var(--color-fg)] mb-1">
      Discover what's been vibe-coded.
    </h1>
    <p class="text-[var(--color-fg-muted)]">
      <span class="tnum font-medium text-[var(--color-fg)]">{projects.length}</span> projects ·
      <span class="tnum font-medium text-[var(--color-fg)]">{skills.length}</span> skills · refreshed daily.
    </p>
  </section>

  <SearchableGrid type="all" />
</Layout>
