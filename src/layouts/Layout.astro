---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'vybify — discover vibe-coded projects & skills',
  description = 'A directory of projects and skills built with AI coding tools.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://vybify.com').href;

const path = Astro.url.pathname;
const isActive = (p: string) => path === p || path.startsWith(p + '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-8VB77KW60J"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-8VB77KW60J');
    </script>
  </head>
  <body>
    <header class="bg-[var(--color-card)] border-b border-[var(--color-border)] sticky top-0 z-30">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 h-14 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2 text-[17px] font-semibold tracking-tight text-[var(--color-fg)] hover:text-[var(--color-accent)] transition">
          <span class="inline-block w-6 h-6 rounded-md bg-[var(--color-accent)] text-white text-xs font-bold leading-6 text-center">v</span>
          vybify
        </a>

        <nav class="flex items-center gap-1 text-sm">
          <a
            href="/"
            class:list={[
              'px-3 py-1.5 rounded-md transition',
              path === '/' ? 'bg-[var(--color-accent-soft)] text-[var(--color-accent)] font-medium' : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg)]',
            ]}
          >
            All
          </a>
          <a
            href="/projects"
            class:list={[
              'px-3 py-1.5 rounded-md transition',
              isActive('/projects') ? 'bg-[var(--color-accent-soft)] text-[var(--color-accent)] font-medium' : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg)]',
            ]}
          >
            Projects
          </a>
          <a
            href="/skills"
            class:list={[
              'px-3 py-1.5 rounded-md transition',
              isActive('/skills') ? 'bg-[var(--color-accent-soft)] text-[var(--color-accent)] font-medium' : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg)]',
            ]}
          >
            Skills
          </a>
          <a
            href="/submit"
            class="ml-2 px-3 py-1.5 rounded-md bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition"
          >
            Submit
          </a>

          <div id="auth-slot" class="ml-1 flex items-center">
            <a
              href="/login"
              data-auth-signin
              class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg)] transition"
            >
              Sign in
            </a>
            <span data-auth-signedin class="hidden items-center gap-2">
              <span data-auth-handle class="text-sm text-[var(--color-fg-muted)] px-2"></span>
              <form method="POST" action="/auth/signout">
                <button
                  type="submit"
                  class="px-3 py-1.5 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg)] transition"
                >
                  Sign out
                </button>
              </form>
            </span>
          </div>
        </nav>
      </div>
    </header>

    <script>
      import { createSupabaseBrowserClient } from '../lib/supabase';
      const supabase = createSupabaseBrowserClient();
      const apply = (user: { email?: string | null; user_metadata?: { name?: string; full_name?: string } } | null) => {
        const signin = document.querySelector<HTMLElement>('[data-auth-signin]');
        const signedin = document.querySelector<HTMLElement>('[data-auth-signedin]');
        const handle = document.querySelector<HTMLElement>('[data-auth-handle]');
        if (!signin || !signedin || !handle) return;
        if (user) {
          signin.classList.add('hidden');
          signedin.classList.remove('hidden');
          signedin.classList.add('flex');
          const name = user.user_metadata?.name || user.user_metadata?.full_name || user.email || 'you';
          handle.textContent = name;
        } else {
          signin.classList.remove('hidden');
          signedin.classList.add('hidden');
          signedin.classList.remove('flex');
        }
      };
      supabase.auth.getUser().then(({ data }) => apply(data.user));
      supabase.auth.onAuthStateChange((_event, session) => apply(session?.user ?? null));
    </script>

    <main class="mx-auto max-w-6xl px-4 sm:px-6 py-8">
      <slot />
    </main>

    <footer class="mt-24 border-t border-[var(--color-border)] bg-[var(--color-card)]">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-[var(--color-fg-muted)]">
        <p>vybify · Refreshed daily from GitHub.</p>
        <nav class="flex items-center gap-4">
          <a href="/submit" class="hover:text-[var(--color-fg)] transition">Submit</a>
          <a href="https://github.com/jakemellman/vybify" class="hover:text-[var(--color-fg)] transition">GitHub</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
